<Window x:Class="ST10480375_PROG6221_POE_PART_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CCP - Cyber Crime Protection"
        Height="660" Width="780"
        Background="#1a1a2e"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="QuickBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="#333366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="3,4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="CCP - Cyber Crime Protection"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#00d4ff"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Cybersecurity Awareness Chatbot"
                       FontSize="11" Foreground="#888888"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Memory bar -->
        <Border Grid.Row="1" Background="#16213e"
                CornerRadius="5" Padding="8,5" Margin="0,0,0,8">
            <TextBlock x:Name="MemoryLabel"
                       Text="Memory:  Name: —   |   Interest: —   |   Last Topic: —"
                       FontSize="10" Foreground="#888888"
                       FontFamily="Consolas"/>
        </Border>

        <!-- Chat display -->
        <Border Grid.Row="2" Background="#0f0f23"
                CornerRadius="5" Padding="5">
            <ScrollViewer x:Name="ChatScroller" VerticalScrollBarVisibility="Auto">
                <RichTextBox x:Name="ChatBox"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="#cccccc"/>
            </ScrollViewer>
        </Border>

        <!-- Quick buttons -->
        <WrapPanel Grid.Row="3" Margin="0,8,0,5">
            <Button Content="phishing"          Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
            <Button Content="password"          Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
            <Button Content="malware"           Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
            <Button Content="start quiz"        Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
            <Button Content="add task"          Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
            <Button Content="view tasks"        Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
            <Button Content="show activity log" Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
            <Button Content="help"              Click="QuickBtn_Click" Style="{StaticResource QuickBtnStyle}"/>
        </WrapPanel>

        <!-- Input row -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     Grid.Column="0"
                     Background="#16213e"
                     Foreground="White"
                     CaretBrush="White"
                     BorderBrush="#00d4ff"
                     BorderThickness="1"
                     Padding="8,6"
                     FontSize="13"
                     Margin="0,0,8,0"
                     KeyDown="InputBox_KeyDown"/>

            <Button x:Name="SendBtn"
                    Grid.Column="1"
                    Content="Send"
                    Background="#00d4ff"
                    Foreground="#1a1a2e"
                    FontWeight="Bold"
                    BorderThickness="0"
                    FontSize="13"
                    Click="SendBtn_Click"/>
        </Grid>
    </Grid>
</Window>